# Database
DATABASE_URL=postgresql+asyncpg://ktru:ktru2024@localhost:5432/ktru

# LLM Provider (choose one: google, openrouter, ollama)
LLM_PROVIDER=google

# Google Gemini API Key
GEMINI_API_KEY=YOUR_API_KEY_HERE

# OpenRouter API Key (alternative)
# OPENROUTER_API_KEY=YOUR_API_KEY_HERE

# Ollama Cloud API Key (for ollama.com)
# IMPORTANT: For security, Ollama Cloud API key should be entered through the UI settings
# and is NOT read from environment variables. This prevents accidental key exposure.
# OLLAMA_CLOUD_API_KEY is intentionally disabled - enter key in app settings instead.

# Ollama local URL (alternative)
# OLLAMA_BASE_URL=http://localhost:11434

# API URL for frontend
VITE_API_URL=http://localhost:8000